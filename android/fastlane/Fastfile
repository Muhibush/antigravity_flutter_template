default_platform(:android)

platform :android do
  desc "Build and upload to Google Play Internal Testing"
  lane :deploy_internal do |options|
    flavor = options[:flavor] || "prod"
    
    # Capitalize flavor for gradle tasks (e.g., dev -> Dev)
    capitalized_flavor = flavor.capitalize
    
    # Path to the JSON key used for Google Play API
    json_key_file = "../play_config.json"
    
    # 1. Update version code and name (optional, could be injected via CI)
    # increment_version_code(...)
    # increment_version_name(...)

    # 2. Build the app bundle
    gradle(
      task: "bundle",
      flavor: capitalized_flavor,
      build_type: "Release",
      properties: {
        "android.injected.signing.store.file" => ENV["KEYSTORE_FILE"] || "keystore.jks",
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias" => ENV["KEY_ALIAS"],
        "android.injected.signing.key.password" => ENV["KEY_PASSWORD"]
      }
    )
    
    # 3. Upload to Internal Track
    # Uncomment the line below once the app is created in Google Play Console
    # upload_to_play_store(
    #   track: "internal",
    #   json_key: json_key_file,
    #   aab: "app/build/outputs/bundle/#{flavor}Release/app-#{flavor}-release.aab"
    # )
  end
end
